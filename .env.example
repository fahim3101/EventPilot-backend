# ============================================
# EventPilot AI - Backend Environment Variables
# ============================================

PORT=5000
NODE_ENV=development

# --- MongoDB ---
# IMPORTANT (DNS / SRV issue fix):
# If you get errors like "querySrv ENOTFOUND" or "Could not connect to any
# servers in your MongoDB Atlas cluster" on some networks/ISPs (common issue
# in Bangladesh with certain routers/DNS), the mongodb+srv:// format fails
# because it depends on DNS SRV record lookups which some networks block.
#
# Fix: Use the standard (non-SRV) connection string instead. In Atlas:
# Connect -> Drivers -> "Standard connection string" (not SRV). It looks like:
# mongodb://user:pass@cluster0-shard-00-00.xxxxx.mongodb.net:27017,cluster0-shard-00-01.xxxxx.mongodb.net:27017,cluster0-shard-00-02.xxxxx.mongodb.net:27017/eventpilot?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority
#
# The db.ts config in this project already has automatic retry + a helpful
# error message pointing you here if SRV resolution fails.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/eventpilot?retryWrites=true&w=majority

# --- Auth ---
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# --- Google OAuth (for social login) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized JS origin: http://localhost:3000
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# --- AI Provider: Groq (free tier, OpenAI-compatible, very fast) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# --- Frontend URL (for CORS) ---
CLIENT_URL=http://localhost:3000
